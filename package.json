{
	"name": "inventory_projects",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev --webpack",
		"build": "next build",
		"start": "next start",
		"check": "biome check . && tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate --out ./drizzle",
		"db:push": "drizzle-kit push",
		"db:seed": "dotenv -e .env -- tsx app/db/seed.ts"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.14",
		"better-auth": "^1.6.13",
		"drizzle-orm": "^0.45.2",
		"next": "16.2.7",
		"postgres": "^3.4.9",
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@biomejs/biome": "^2.4.16",
		"@tailwindcss/postcss": "^4",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"dotenv-cli": "^11.0.0",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9",
		"eslint-config-next": "16.2.7",
		"tailwindcss": "^4",
		"tsx": "^4.22.4",
		"typescript": "^5"
	}
}
